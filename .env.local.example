# ─── Supabase ────────────────────────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# ─── Clerk ───────────────────────────────────────────────────────────────────
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=
CLERK_WEBHOOK_SECRET=
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up
NEXT_PUBLIC_CLERK_AFTER_SIGN_IN_URL=/app/dashboard
NEXT_PUBLIC_CLERK_AFTER_SIGN_UP_URL=/onboarding/brand

# ─── Razorpay (India — INR) ──────────────────────────────────────────────────
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
RAZORPAY_WEBHOOK_SECRET=
RAZORPAY_PLAN_ID_STARTER=
RAZORPAY_PLAN_ID_GROWTH=
RAZORPAY_PLAN_ID_AGENCY=

# ─── Stripe (USD / EUR) ──────────────────────────────────────────────────────
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
STRIPE_PRICE_ID_STARTER_USD=
STRIPE_PRICE_ID_STARTER_EUR=
STRIPE_PRICE_ID_GROWTH_USD=
STRIPE_PRICE_ID_GROWTH_EUR=
STRIPE_PRICE_ID_AGENCY_USD=
STRIPE_PRICE_ID_AGENCY_EUR=
STRIPE_ANNUAL_COUPON_ID=

# ─── Email ───────────────────────────────────────────────────────────────────
RESEND_API_KEY=

# ─── AI ──────────────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=
OPENAI_API_KEY=

# ─── Data collection ─────────────────────────────────────────────────────────
APIFY_API_TOKEN=
META_SYSTEM_USER_TOKEN=       # Meta Business Suite system user token — for Ads Library API (ads_archive)

# ─── Company intelligence (NinjaPear / Nubela) ───────────────────────────────
NINJAPEAR_API_KEY=

# ─── VPN / geo detection ─────────────────────────────────────────────────────
IPQUALITYSCORE_API_KEY=

# ─── OAuth channel connections (Settings → Connected channels) ───────────────
# Meta Ads — Facebook App (App type: Business)
#   Callback: https://emayil.com/api/oauth/meta/callback
FACEBOOK_APP_ID=
FACEBOOK_APP_SECRET=
#
# Instagram Business Login — separate Instagram app (App ID ≠ Facebook App ID)
#   Callback: https://emayil.com/api/oauth/instagram/callback
#   Deauthorize: https://emayil.com/api/instagram/deauthorize
#   Data deletion: https://emayil.com/api/instagram/deletion
INSTAGRAM_APP_ID=
INSTAGRAM_APP_SECRET=
#
# Google (Ads + YouTube) — Google Cloud OAuth 2.0 Client
#   Callback: https://emayil.com/api/oauth/google/callback
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
#
# LinkedIn Pages Data Portability — dedicated LinkedIn app (standalone product)
#   Callback: https://emayil.com/api/oauth/linkedin/callback
LINKEDIN_CLIENT_ID=
LINKEDIN_CLIENT_SECRET=

# ─── HubSpot (contact / demo form) ──────────────────────────────────────────
# Portal ID: visible in your HubSpot URL (app.hubspot.com/contacts/{portalId}/)
# Form GUID: create a form in HubSpot with fields firstname, email, company,
#            jobtitle, message — GUID is in the form's embed code
HUBSPOT_PORTAL_ID=
HUBSPOT_FORM_GUID=

# ─── Analytics ───────────────────────────────────────────────────────────────
# Google Tag Manager — Container ID from GTM → Admin → Container Settings
NEXT_PUBLIC_GTM_ID=

# ─── Admin ───────────────────────────────────────────────────────────────────
ADMIN_PASSWORD_HASH=

# ─── App ─────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=https://emayil.com
NEXT_PUBLIC_APP_ENV=production
