#!/bin/sh
#
# pre-commit — Git hook
# Blocks commits where source files are staged but CHANGELOG.md is not.
#
# Install (run once from repo root):
#   node scripts/hooks/install.js
#
# What it checks:
#   - Any .ts / .tsx / .sql / .css files are staged
#   - AND docs/changelog/CHANGELOG.md is NOT staged
#   → Abort with instructions
#
# Bypasses:
#   - Commits touching only docs, config, or non-code files pass through
#   - Use --no-verify only in genuine emergencies (adds a comment to the commit)

STAGED_SOURCE=$(git diff --cached --name-only | grep -E '\.(ts|tsx|sql|css|js|jsx)$' | grep -v 'node_modules' | grep -v '\.next/')
STAGED_CHANGELOG=$(git diff --cached --name-only | grep -i 'CHANGELOG')

if [ -n "$STAGED_SOURCE" ] && [ -z "$STAGED_CHANGELOG" ]; then
  echo ""
  echo "  ✗ Commit blocked — source files staged but CHANGELOG.md not updated."
  echo ""
  echo "  Staged source files:"
  echo "$STAGED_SOURCE" | sed 's/^/    • /'
  echo ""
  echo "  Add an entry to docs/changelog/CHANGELOG.md describing these changes,"
  echo "  then stage it with: git add docs/changelog/CHANGELOG.md"
  echo ""
  echo "  To bypass in an emergency: git commit --no-verify"
  echo ""
  exit 1
fi

exit 0
